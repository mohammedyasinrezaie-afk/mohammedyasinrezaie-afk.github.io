  <style>
    :root {
      --sand: #e8d5b0;
      --ocean: #1a3a4a;
      --teal: #2a7f8f;
      --accent: #f0a500;
      --light: #f5f0e8;
      --dark: #0f1e26;
      --text: #1a2830;
      --muted: #5a7080;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--light);
      color: var(--text);
      line-height: 1.7;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      background: rgba(15,30,38,0.95);
      backdrop-filter: blur(8px);
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    nav a { color: var(--sand); text-decoration: none; font-family: 'Space Mono', monospace; font-size: 0.8rem; letter-spacing: 0.05em; }
    nav a:hover { color: var(--accent); }
    .nav-logo { font-size: 0.9rem; font-weight: 700; color: var(--accent) !important; }

    /* HERO */
    .hero {
      min-height: 100vh;
      background: var(--ocean);
      display: flex; align-items: flex-end;
      padding: 8rem 2rem 4rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 70% 40%, rgba(42,127,143,0.25) 0%, transparent 60%),
                  radial-gradient(ellipse at 20% 80%, rgba(240,165,0,0.1) 0%, transparent 50%);
    }
    .hero-grid {
      position: absolute; inset: 0; opacity: 0.05;
      background-image: linear-gradient(var(--teal) 1px, transparent 1px),
                        linear-gradient(90deg, var(--teal) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    .hero-content { position: relative; max-width: 900px; }
    .hero-tag {
      display: inline-block;
      background: var(--teal); color: white;
      font-family: 'Space Mono', monospace; font-size: 0.7rem;
      padding: 0.3rem 0.8rem; border-radius: 2px;
      letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    h1 {
      font-family: 'Space Mono', monospace;
      font-size: clamp(2.2rem, 6vw, 4.5rem);
      color: white;
      line-height: 1.1;
      margin-bottom: 1.5rem;
    }
    h1 span { color: var(--accent); }
    .hero-sub {
      color: var(--sand); font-size: 1.1rem; font-weight: 300;
      max-width: 600px; margin-bottom: 2rem;
    }
    .hero-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .chip {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.15);
      color: var(--sand); font-family: 'Space Mono', monospace;
      font-size: 0.7rem; padding: 0.35rem 0.8rem; border-radius: 100px;
    }

    /* MAIN CONTENT */
    main { max-width: 860px; margin: 0 auto; padding: 5rem 2rem; }

    section { margin-bottom: 5rem; }

    .section-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--teal); margin-bottom: 0.6rem;
    }
    h2 {
      font-family: 'Space Mono', monospace;
      font-size: 1.6rem; color: var(--ocean);
      margin-bottom: 1.2rem;
      padding-bottom: 0.6rem;
      border-bottom: 2px solid var(--sand);
    }
    p { color: var(--text); margin-bottom: 1rem; font-size: 1rem; }

    /* CARDS GRID */
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.2rem; margin-top: 1.5rem; }
    .card {
      background: white;
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 1.4rem;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .card-icon { font-size: 1.6rem; margin-bottom: 0.6rem; }
    .card h3 { font-family: 'Space Mono', monospace; font-size: 0.85rem; color: var(--ocean); margin-bottom: 0.4rem; }
    .card p { font-size: 0.88rem; color: var(--muted); margin: 0; }

    /* SPEC TABLE */
    .spec-table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    .spec-table tr { border-bottom: 1px solid #e5e5e5; }
    .spec-table tr:last-child { border: none; }
    .spec-table td { padding: 0.7rem 0.5rem; font-size: 0.9rem; }
    .spec-table td:first-child { font-family: 'Space Mono', monospace; font-size: 0.78rem; color: var(--teal); width: 40%; }

    /* TIMELINE */
    .timeline { border-left: 2px solid var(--teal); padding-left: 1.5rem; margin-top: 1.5rem; }
    .tl-item { position: relative; margin-bottom: 1.8rem; }
    .tl-item::before {
      content: '';
      position: absolute; left: -1.9rem; top: 0.4rem;
      width: 10px; height: 10px;
      background: var(--accent); border-radius: 50%;
    }
    .tl-date { font-family: 'Space Mono', monospace; font-size: 0.72rem; color: var(--muted); margin-bottom: 0.3rem; }
    .tl-item h4 { font-size: 0.95rem; font-weight: 600; color: var(--ocean); margin-bottom: 0.3rem; }
    .tl-item p { font-size: 0.88rem; color: var(--muted); margin: 0; }

    /* RESULT BOXES */
    .results-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-top: 1.5rem; }
    .result-box {
      background: var(--ocean); color: white;
      border-radius: 6px; padding: 1.4rem; text-align: center;
    }
    .result-num {
      font-family: 'Space Mono', monospace;
      font-size: 1.8rem; color: var(--accent);
      display: block; margin-bottom: 0.3rem;
    }
    .result-label { font-size: 0.8rem; opacity: 0.75; }

    /* CALLOUT */
    .callout {
      background: #fff8e6;
      border-left: 3px solid var(--accent);
      padding: 1rem 1.2rem; border-radius: 0 6px 6px 0;
      margin-top: 1rem;
    }
    .callout p { font-size: 0.9rem; color: var(--text); margin: 0; }

    /* BACK LINK */
    .back-link {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'Space Mono', monospace; font-size: 0.8rem;
      color: var(--teal); text-decoration: none;
      margin-bottom: 3rem; margin-top: 1rem;
    }
    .back-link:hover { color: var(--accent); }

    /* PHOTO */
    .project-photo {
      width: 100%; border-radius: 8px;
      overflow: hidden; margin-top: 1.8rem;
      border: 1px solid #ddd;
      box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    }
    .project-photo img {
      width: 100%; display: block;
      object-fit: cover; max-height: 480px;
    }
    .photo-caption {
      background: var(--ocean); color: var(--sand);
      font-family: 'Space Mono', monospace; font-size: 0.72rem;
      padding: 0.6rem 1rem; letter-spacing: 0.03em;
    }

    @media (max-width: 600px) {
      nav { padding: 0.8rem 1rem; }
      main { padding: 3rem 1.2rem; }
    }
